{
  "name": "streetmp-os",
  "version": "0.1.0",
  "private": true,
  "description": "Streetmp OS — The AI Career Intelligence Platform Monorepo",
  "workspaces": [
    "apps/*",
    "apps/os-kernel/services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:load": "k6 run apps/os-kernel/tests/load/k6-script.js",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres-vault",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "db:shell": "docker exec -it streetmp_postgres psql -U ${DB_USER:-streetmp} -d ${DB_NAME:-streetmp_os}",
    "dev:services": "turbo run dev --concurrency=25",
    "dev": "docker compose up -d && sleep 3 && npm run dev:services",
    "simulate:traffic": "ts-node apps/os-kernel/scripts/simulate_global_traffic.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/react": "^3.0.144",
    "@hookform/resolvers": "^5.2.2",
    "ai": "^6.0.142",
    "ethers": "^6.16.0",
    "express-rate-limit": "^8.3.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  }
}
