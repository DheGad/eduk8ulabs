# Router Service Environment Configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=

# Payments
STRIPE_SECRET_KEY=
RAZORPAY_KEY_SECRET=
STRIPE_WEBHOOK_SECRET=

# Internal Services
VAULT_SERVICE_URL=http://localhost:4002
USAGE_SERVICE_URL=http://localhost:4004
INTERNAL_ROUTER_SECRET=

# Admin
STREETMP_ADMIN_SECRET=

# Server
PORT=4000
NODE_ENV=development

# Transactional Email (SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_ADDRESS="StreetMP OS" <noreply@os.streetmp.com>

