{
  "name": "@streetmp-os/router-service",
  "version": "0.1.0",
  "private": true,
  "description": "Router Service — The LLM Execution Engine API Gateway",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:security": "node --experimental-vm-modules node_modules/.bin/jest --config jest.security.config.mjs",
    "test:security:offline": "SKIP_LIVE_TESTS=true node --experimental-vm-modules node_modules/.bin/jest --config jest.security.config.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@sentry/node": "^10.47.0",
    "@streetmp-os/config": "*",
    "@types/ioredis": "^4.28.10",
    "@types/pg": "^8.20.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.38.0",
    "pg": "^8.20.0",
    "stripe": "^20.4.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.23",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
