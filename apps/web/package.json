{
  "name": "@streetmp-os/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "chmod -R u+w .next 2>/dev/null || true && rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:public": "SKIP_AUTH_TESTS=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.11.1",
    "@sentry/nextjs": "^10.47.0",
    "@streetmp/sdk": "*",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@types/pg": "^8.20.0",
    "bcrypt": "^6.0.0",
    "lucide-react": "^0.577.0",
    "luxon": "^3.7.2",
    "next": "^15.3.0",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/bcrypt": "^6.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0"
  }
